# Server port (defaults to 5000)
PORT=5000

# Mongo connection string
MONGO_URL=mongodb://localhost:27017/profilizepro

# JWT signing secret (must match the client's SECRET_KEY)
SECRET_KEY=thisisthesecretkeythathasnottobechangedatanypointoftime

# Used server-side by the assignment PATCH route's updateAssignment() fetch.
NEXT_PUBLIC_UPDATE_ASSIGNMENT=http://localhost:5000/api/v1/assignment

# LLM (Google Gemini via the Vercel AI SDK)
GOOGLE_GENERATIVE_AI_API_KEY=your_google_key
# Optional overrides
# LLM_MODEL=gemini-2.5-flash
# LLM_REQUEST_TIMEOUT_MS=30000

# Email (Resend)
RESEND_API_KEY=your_resend_key
# EMAIL_FROM=ProfilizePro <onboarding@resend.dev>
